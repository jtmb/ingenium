{
  "name": "ingenium-email",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./lib/*": { "import": "./dist/lib/*.js", "types": "./dist/lib/*.d.ts" }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "imapflow": "^1.0.0",
    "nodemailer": "^6.9.0",
    "mailparser": "^3.7.0",
    "google-auth-library": "^9.0.0",
    "@azure/msal-node": "^2.0.0",
    "ingenium-core": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/nodemailer": "^6.4.0"
  }
}
