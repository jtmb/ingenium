{
  "name": "ingenium-email",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lib/*": {
      "import": "./dist/lib/*.js",
      "types": "./dist/lib/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@azure/msal-node": "^2.0.0",
    "google-auth-library": "^9.0.0",
    "imapflow": "^1.0.0",
    "ingenium-core": "*",
    "mailparser": "^3.7.0",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.0",
    "typescript": "^5.6.0",
    "vitest": "^3.1.1"
  }
}
