{
  "name": "ingenium-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": { "import": "./dist/lib/index.js", "types": "./dist/lib/index.d.ts" },
    "./lib/*": { "import": "./dist/lib/*.js", "types": "./dist/lib/*.d.ts" }
  },
  "scripts": {
    "build": "tsc && cp -r data dist/data",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/better-sqlite3": "^7.6.0",
    "vitest": "^2.0.0"
  }
}
