{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "permission": "allow",
  "mcp": {
    "ingenium": {
      "type": "local",
      "command": [
        "node",
        "packages/ingenium-extension/dist/scripts/mcp-server.js"
      ],
      "enabled": true,
      "environment": {
        "INGENIUM_API_URL": "http://localhost:4097/api/v1",
        "INGENIUM_API_TIMEOUT": "10000",
        "LOG_LEVEL": "info",
        "INGENIUM_PROJECT": "gh-llm-bootstrap"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--caps=vision",
        "--headless",
        "--executable-path",
        "/home/brajam/.cache/ms-playwright/chromium-1232/chrome-linux64/chrome"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "packages/ingenium-extension/auto-observer.ts",
    "packages/ingenium-extension/observer.ts",
    "packages/ingenium-extension/resource-sync.ts"
  ]
}
