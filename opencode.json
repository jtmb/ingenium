{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "permission": "allow",
  "mcp": {
    // Thread retired — migrated to Docs RAG. Remove after verification.
    "thread": {
      "type": "local",
      "command": [
        "/home/brajam/.thread-bridge/.venv/bin/python",
        "-m",
        "thread_bridge.bridge"
      ],
      "cwd": "/home/brajam/.thread-bridge",
      "enabled": false,
      "environment": {
        "THREAD_SERVER_URL": "http://localhost:5000",
        "THREAD_DEFAULT_SESSION": "gh-llm-bootstrap",
        "THREAD_REQUEST_TIMEOUT": "10",
        "THREAD_API_TOKEN": "<YOUR_THREAD_API_TOKEN>"
      }
    },
    "ingenium": {
      "type": "local",
      "command": [
        "node",
        "packages/ingenium-extension/dist/scripts/mcp-server.js"
      ],
      "enabled": true,
      "environment": {
        "INGENIUM_API_URL": "http://localhost:4097/api/v1",
        "INGENIUM_API_TIMEOUT": "10000",
        "LOG_LEVEL": "info",
        "INGENIUM_PROJECT": "gh-llm-bootstrap"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--caps=vision",
        "--headless",
        "--executable-path",
        "/home/brajam/.cache/ms-playwright/chromium-1232/chrome-linux64/chrome"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "packages/ingenium-extension/auto-observer.ts",
    "packages/ingenium-extension/observer.ts",
    "packages/ingenium-extension/onboarding-sync.ts",
    "packages/ingenium-extension/skill-sync.ts"
  ]
}