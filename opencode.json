{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "permission": "allow",
  "mcp": {
    "ingenium": {
      "type": "local",
      "command": [
        "/usr/bin/env",
        "node",
        "services/ingenium-server/dist/scripts/mcp-server.js"
      ],
      "enabled": true,
      "environment": {
        "PATH": "/home/brajam/.local/bin:/usr/local/bin:/usr/bin:/bin",
        "INGENIUM_API_URL": "http://localhost:4097/api/v1",
        "INGENIUM_API_TIMEOUT": "10000",
        "LOG_LEVEL": "info",
        "INGENIUM_PROJECT": "ingenium"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "/usr/bin/env",
        "playwright-mcp",
        "--caps=vision",
        "--browser",
        "chromium"
      ],
      "enabled": true,
      "environment": {
        "PATH": "/home/brajam/.local/bin:/usr/local/bin:/usr/bin:/bin"
      },
      "timeout": 60000
    }
  },
  "plugin": [
    "packages/ingenium-extension/auto-observer.ts",
    "packages/ingenium-extension/observer.ts",
    "packages/ingenium-extension/resource-sync.ts"
  ]
}
