{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".agents/instructions/*/SKILL.md",
    ".agents/tools/*/SKILL.md"
  ],
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow"
  },
  "agent": {
    "build": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.3,
      "prompt": "You are an expert software engineer. Follow the project's AGENTS.md for skill loading protocol. Always load relevant skills before writing code."
    }
  },
  "mcp": {
    "thread": {
      "type": "local",
      "command": ["/home/brajam/.thread-bridge/.venv/bin/python", "-m", "thread_bridge.bridge"],
      "cwd": "/home/brajam/.thread-bridge",
      "enabled": true,
      "env": {
        "THREAD_SERVER_URL": "http://localhost:5000",
        "THREAD_DEFAULT_SESSION": "gh-llm-bootstrap",
        "THREAD_REQUEST_TIMEOUT": "10",
        "THREAD_API_TOKEN": "eyJhbGciOiJIUzI1NiIsInR5cCI6IlRIUkVBRCJ9.eyJzdWIiOiJhZG1pbiIsImlhdCI6MTc4MzIwODEwMH0.QDI4WTeyPVngwpXRdSUuzXYplyhK6KvWJiyhRCfEdc0"
      }
    }
  }
}
