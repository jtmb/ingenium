{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow"
  },
  "mcp": {
    "thread": {
      "type": "local",
      "command": [
        "/home/brajam/.thread-bridge/.venv/bin/python",
        "-m",
        "thread_bridge.bridge"
      ],
      "cwd": "/home/brajam/.thread-bridge",
      "enabled": true,
      "environment": {
        "THREAD_SERVER_URL": "http://localhost:5000",
        "THREAD_DEFAULT_SESSION": "gh-llm-bootstrap",
        "THREAD_REQUEST_TIMEOUT": "10",
        "THREAD_API_TOKEN": "eyJhbGciOiJIUzI1NiIsInR5cCI6IlRIUkVBRCJ9.eyJzdWIiOiJhZG1pbiIsImlhdCI6MTc4MzIyMjQzMX0.ULrWu0TAj8A-6q3Uf5PnOw70RIPIwRDETitq-Mopf0k"
      }
    },
    "ingenium": {
      "type": "local",
      "command": [
        "node",
        "packages/ingenium-extension/dist/scripts/mcp-server.js"
      ],
      "enabled": true,
      "environment": {
        "INGENIUM_API_URL": "http://localhost:4097/api/v1",
        "INGENIUM_API_TIMEOUT": "10000",
        "LOG_LEVEL": "info"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--caps=vision"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "packages/ingenium-extension/observer.ts",
    "packages/ingenium-extension/auto-observer.ts",
    "packages/ingenium-extension/skill-sync.ts"
  ]
}
