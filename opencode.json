{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".agents/skills/orchestrator-primer/SKILL.md",
    ".agents/skills/generic-conventions/SKILL.md",
    ".agents/skills/repo-context/SKILL.md",
    ".agents/skills/local-models/SKILL.md"
  ],
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow"
  },
  "mcp": {
    "kaban": {
      "type": "local",
      "command": ["kaban", "mcp"],
      "enabled": true,
      "environment": {
        "KABAN_PATH": "/home/brajam/repos/gh-llm-bootstrap"
      }
    },
    "thread": {
      "type": "local",
      "command": ["/home/brajam/.thread-bridge/.venv/bin/python", "-m", "thread_bridge.bridge"],
      "cwd": "/home/brajam/.thread-bridge",
      "enabled": true,
      "environment": {
        "THREAD_SERVER_URL": "http://localhost:5000",
        "THREAD_DEFAULT_SESSION": "gh-llm-bootstrap",
        "THREAD_REQUEST_TIMEOUT": "10",
        "THREAD_API_TOKEN": "eyJhbGciOiJIUzI1NiIsInR5cCI6IlRIUkVBRCJ9.eyJzdWIiOiJhZG1pbiIsImlhdCI6MTc4MzIyMjQzMX0.ULrWu0TAj8A-6q3Uf5PnOw70RIPIwRDETitq-Mopf0k"
      }
    },
    "ingenium": {
      "type": "local",
      "command": ["node", "/home/brajam/repos/gh-llm-bootstrap/services/ingenium-server/dist/scripts/mcp-server.js"],
      "enabled": true,
      "environment": {
        "INGENIUM_API_URL": "http://localhost:4097/api/v1",
        "INGENIUM_API_TIMEOUT": "10000",
        "LOG_LEVEL": "info"
      }
    }
  }
}
